<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ====== CAMERA PREVIEW (FULLSCREEN) ====== -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewViewReadText"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ====== OPTIONAL OVERLAY FOR DRAWING BOXES ====== -->

    <!-- ====== DETECTED TEXT PREVIEW ====== -->
    <TextView
        android:id="@+id/detectedTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#66000000"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:padding="12dp"
        android:maxLines="4"
        android:gravity="center"
        android:visibility="visible"
        app:layout_constraintBottom_toTopOf="@id/btnToggleReading"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ====== START / STOP READING BUTTON ====== -->
    <Button
        android:id="@+id/btnToggleReading"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Start Reading"
        android:backgroundTint="#66000000"
        android:textColor="#FFFFFF"
        android:padding="14dp"
        android:textSize="18sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="20dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
